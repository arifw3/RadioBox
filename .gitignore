# Dart tooling — packages/ and tool/ don't have their own .gitignore, so
# these live at the root. app/ ships its own (flutter create-generated)
# .gitignore for Android/iOS build artifacts, which git applies on top of
# this one.
.dart_tool/
.packages
build/

# Library lockfiles aren't meaningful to pin — only the app and the
# radio_sync script (both "applications") commit theirs.
packages/*/pubspec.lock

# IDE / OS
.idea/
.vscode/
.claude/
*.iml
.DS_Store
Thumbs.db

# Raw scraped source for the one-off custom-station import
# (tool/radio_sync/bin/import_custom_stations.dart) — already folded into
# radios.json + images/, no need to commit the unfiltered originals.
tum_radyolar.json
images_raw_source/

# Source files for branding assets (already copied into
# app/assets/branding/, app/android/.../mipmap-*, app/ios/.../AppIcon.appiconset)
# and one-off UI mockup references — not part of the app or the CDN
# station-image mirror.
/icon.png
/logo.png
/logo2.png
images/icons/
images/*.webp

# Local test artifacts from device runs.
run_debug*.log
screenshot*.png
images/design/
